<?xml version="1.0" encoding="utf-8" standalone="no"?><plugin xmlns="http://www.phonegap.com/ns/plugins/1.0" xmlns:amazon="http://schemas.android.com/apk/lib/com.amazon.device.ads" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:m3="http://schemas.microsoft.com/appx/2014/manifest" xmlns:rim="http://www.blackberry.com/ns/widgets" xmlns:tools="http://schemas.android.com/tools" xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10" id="admob-plus-cordova" version="1.29.0">
    <name>admob-plus-cordova</name>
    <description>Plugin enables Monetization with Google AdMob banners, interstitials, rewarded video, and native ads on iOS and Android.</description>
    <js-module name="AdMob" src="www/admob.js">
        <clobbers target="admob"/>
    </js-module>

    <engines>
        <engine name="cordova" version="&gt;=7.0.0"/>
        <engine name="cordova-android" version="&gt;=6.0.0"/>
        <engine name="cordova-ios" version="&gt;=5.0.0"/>
    </engines>

    <platform name="android">
        <preference default="ca-app-pub-xxx~yyy" name="APP_ID_ANDROID"/>
        <preference default="23.2.0" name="PLAY_SERVICES_VERSION"/>

        <config-file parent="/manifest/application" target="AndroidManifest.xml">
            <activity android:configChanges="keyboard|keyboardHidden|orientation|screenLayout|uiMode|screenSize|smallestScreenSize" android:excludeFromRecents="true" android:exported="true" android:name="com.google.android.gms.ads.AdActivity" android:noHistory="true"/>
            <meta-data android:name="com.google.android.gms.ads.APPLICATION_ID" android:value="$APP_ID_ANDROID"/>
            <meta-data android:name="com.google.android.gms.ads.DELAY_APP_MEASUREMENT_INIT" android:value="true"/>
            <meta-data android:name="com.google.android.gms.ads.flag.OPTIMIZE_INITIALIZATION" android:value="true"/>
            <meta-data android:name="com.google.android.gms.ads.flag.OPTIMIZE_AD_LOADING" android:value="true"/>
            <meta-data android:name="com.google.android.gms.ads.flag.INTEGRATION_MANAGER" android:value="webview"/>
        </config-file>

        <config-file parent="/*" target="res/xml/config.xml">
            <feature name="AdMob">
                <param name="android-package" value="admob.plus.cordova.AdMob"/>
            </feature>
        </config-file>

        <framework src="com.google.android.gms:play-services-ads:$PLAY_SERVICES_VERSION"/>

        <source-file src="src/android/core/util.kt" target-dir="app/src/main/kotlin/admob/plus/core"/>
        <source-file src="src/android/cordova/AdMob.kt" target-dir="app/src/main/kotlin/admob/plus/cordova"/>
        <source-file src="src/android/cordova/ExecuteContext.kt" target-dir="app/src/main/kotlin/admob/plus/cordova"/>
        <source-file src="src/android/cordova/Generated.kt" target-dir="app/src/main/kotlin/admob/plus/cordova"/>
        <source-file src="src/android/cordova/ads/AdBase.kt" target-dir="app/src/main/kotlin/admob/plus/cordova/ads"/>
        <source-file src="src/android/cordova/ads/WebViewAd.kt" target-dir="app/src/main/kotlin/admob/plus/cordova/ads"/>
        <source-file src="src/android/cordova/ads/AppOpen.kt" target-dir="app/src/main/kotlin/admob/plus/cordova/ads"/>
        <source-file src="src/android/cordova/ads/Banner.kt" target-dir="app/src/main/kotlin/admob/plus/cordova/ads"/>
        <source-file src="src/android/cordova/ads/Interstitial.kt" target-dir="app/src/main/kotlin/admob/plus/cordova/ads"/>
        <source-file src="src/android/cordova/ads/Native.kt" target-dir="app/src/main/kotlin/admob/plus/cordova/ads"/>
        <source-file src="src/android/cordova/ads/Rewarded.kt" target-dir="app/src/main/kotlin/admob/plus/cordova/ads"/>
        <source-file src="src/android/cordova/ads/RewardedInterstitial.kt" target-dir="app/src/main/kotlin/admob/plus/cordova/ads"/>

        <hook src="hooks/add-tools-namespace.js" type="after_platform_add"/>
        <hook src="hooks/add-tools-namespace.js" type="after_prepare"/>
        <hook src="hooks/fix-adactivity-manifest.js" type="after_platform_add"/>
        <hook src="hooks/fix-android-manifest.js" type="after_prepare"/>

        <!-- AUTOGENERATED: ANDROID_BEGIN -->
        <!-- AUTOGENERATED: ANDROID_END -->
    </platform>

    <platform name="ios">
        <preference default="ca-app-pub-xxx~yyy" name="APP_ID_IOS"/>
        <preference default="This identifier will be used to deliver personalized ads to you." name="USAGE"/>
        <preference default="false" name="disableSDKCrashReporting"/>

        <config-file parent="/*" target="config.xml">
            <feature name="AdMob">
                <param name="ios-package" value="AMBPlugin"/>
            </feature>
        </config-file>

        <config-file parent="GADApplicationIdentifier" target="*-Info.plist">
            <string>$APP_ID_IOS</string>
        </config-file>

        <config-file parent="GADDelayAppMeasurementInit" target="*-Info.plist">
            <true/>
        </config-file>

        <config-file parent="NSAppTransportSecurity" target="*-Info.plist">
            <dict>
                <key>NSAllowsArbitraryLoads</key>
                <true/>
                <key>NSAllowsArbitraryLoadsForMedia</key>
                <true/>
                <key>NSAllowsArbitraryLoadsInWebContent</key>
                <true/>
            </dict>
        </config-file>

        <config-file parent="NSUserTrackingUsageDescription" target="*-Info.plist">
            <string>$USAGE</string>
        </config-file>

        <config-file parent="GADIntegrationManager" target="*-Info.plist">
            <string>webview</string>
        </config-file>

